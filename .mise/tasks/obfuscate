#!/usr/bin/env bash
#MISE description="Obfuscate note filenames (reversible via deobfuscate)"
#USAGE flag "--dir <dir>" help="Notes directory relative to repo root (default: notes)"
#USAGE flag "--dry-run" help="Show what would be renamed without doing it"
#USAGE arg "[files]..." help="Specific files to obfuscate (relative to notes dir). Omit for all."
set -eo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"
source "$MISE_CONFIG_ROOT/lib/obfuscate.sh"
source "$MISE_CONFIG_ROOT/lib/suppress.sh"
notes_dir="${usage_dir:-notes}"
abs_notes_dir="$TARGET_DIR/$notes_dir"
manifest="$abs_notes_dir/.manifest"

if [ ! -d "$abs_notes_dir" ]; then
  echo "Error: notes directory not found: $abs_notes_dir" >&2
  exit 1
fi

# Parse variadic args safely (mise wraps multi-word args in single quotes).
# xargs respects shell quoting so spaces in filenames work correctly.
# Limitation: backslashes in filenames are treated as escape characters by xargs.
ARGS=()
if [ -n "${usage_files:-}" ]; then
  while IFS= read -r arg; do
    # Strip notes_dir prefix if provided (e.g. "notes/alpha.md" → "alpha.md")
    arg="${arg#"${notes_dir}/"}"
    ARGS+=("$arg")
  done < <(printf '%s' "${usage_files}" | xargs printf '%s\n')
fi

if [ "${usage_dry_run:-}" = "true" ]; then
  # Dry-run: show what would be renamed without doing it.
  # Use the same classification logic as rename_to_obfuscated.
  if [ ${#ARGS[@]} -gt 0 ]; then
    for relpath in "${ARGS[@]}"; do
      [[ "$relpath" == ".manifest" ]] && continue
      [ ! -f "$abs_notes_dir/$relpath" ] && continue
      base=$(basename "$relpath")
      manifest_has_id "$manifest" "$base" && continue
      echo "  $relpath → (will be assigned)"
    done
  else
    while IFS= read -r f; do
      [ ! -f "$f" ] && continue
      relpath="${f#"$abs_notes_dir"/}"
      [[ "$relpath" == ".manifest" ]] && continue
      base=$(basename "$f")
      manifest_has_id "$manifest" "$base" && continue
      existing_id=$(manifest_id_for_name "$manifest" "$relpath" || true)
      if [ -n "$existing_id" ]; then
        echo "  $relpath → $existing_id"
      else
        echo "  $relpath → (will be assigned)"
      fi
    done < <(find "$abs_notes_dir" -type f | sort)
  fi
  exit 0
fi

# Clear status suppression so git sees the real state for staging.
# In scoped mode, we need to find the IDs for files being re-obfuscated.
if [ ${#ARGS[@]} -gt 0 ]; then
  scoped_ids=()
  for relpath in "${ARGS[@]}"; do
    id=$(manifest_id_for_name "$manifest" "$relpath" || true)
    [ -n "$id" ] && scoped_ids+=("$id")
  done
  [ ${#scoped_ids[@]} -gt 0 ] && clear_status_suppression "$abs_notes_dir" "${scoped_ids[@]}"
else
  clear_status_suppression "$abs_notes_dir"
fi

# Perform the rename via Layer 1
# Exit codes: 0=success, 2=nothing to do, 1=error
# Use && rc=0 || rc=$? to capture exit code without triggering errexit.
output=$(rename_to_obfuscated "$abs_notes_dir" "${ARGS[@]}") && rc=0 || rc=$?
if [ $rc -eq 2 ]; then
  echo "Nothing to obfuscate."
  exit 0
elif [ $rc -ne 0 ]; then
  echo "Error: obfuscation failed" >&2
  exit $rc
fi

manifest_entry_matches_head() {
  local id="$1" relpath="$2"
  git -C "$TARGET_DIR" cat-file --filters "HEAD:$notes_dir/.manifest" 2>/dev/null \
    | awk -F '\t' -v id="$id" -v relpath="$relpath" '
        $1 == id && $2 == relpath { found=1 }
        END { exit found ? 0 : 1 }
      '
}

# Stage the results: add obfuscated files, remove readable names from index.
# In full mode, stage the manifest normally. In scoped mode, stage it only when
# one of the scoped files needs a manifest update in HEAD. This prevents an
# unrelated uncommitted manifest entry (for a skipped new note) from leaking into
# a commit when the pre-commit hook obfuscates a modified known note.
new_count=0
stage_manifest=false
[ ${#ARGS[@]} -eq 0 ] && stage_manifest=true
while IFS=$'\t' read -r relpath id; do
  git -C "$TARGET_DIR" add "$notes_dir/$id"
  git -C "$TARGET_DIR" rm --cached --quiet "$notes_dir/$relpath" 2>/dev/null || true
  if ! manifest_entry_matches_head "$id" "$relpath"; then
    stage_manifest=true
  fi
  echo "  $relpath → $id"
  ((new_count++)) || true
done <<< "$output"

if $stage_manifest; then
  git -C "$TARGET_DIR" add "$manifest"
fi

echo ""
echo "Manifest written: $manifest"
echo "Obfuscated $new_count file(s)."
