#!/usr/bin/env bash
#MISE description="Install git hooks for obfuscation (pre-commit, post-commit, post-merge)"
#USAGE flag "--dir <dir>" help="Notes directory relative to repo root (default: notes)"
set -eo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"
source "$MISE_CONFIG_ROOT/lib/hooks.sh"
require_git

notes_dir="${usage_dir:-notes}"
manifest="$TARGET_DIR/$notes_dir/.manifest"

if ! is_initialized && [ ! -f "$manifest" ]; then
  echo "No notes manifest found and git-crypt is not initialized; not installing hooks."
  echo "Run 'notes setup --yes' to initialize notes in this repo."
  exit 0
fi

install_encryption_hook
install_obfuscation_hook "$notes_dir"
install_deobfuscation_hook "$notes_dir"
install_manifest_merge_driver "$notes_dir"

echo "Installed hooks:"
echo "  pre-commit.d/encryption — rejects plaintext staged encrypted files"
echo "  pre-commit.d/obfuscation — auto-obfuscates staged readable names"
echo "  post-commit.d/deobfuscation — restores readable names after commit"
echo "  post-merge.d/deobfuscation — restores readable names after pull"
echo "  post-checkout.d/deobfuscation — reconciles readable names after branch checkout"
echo "  merge driver — auto-merges .manifest on pull/merge/rebase"
