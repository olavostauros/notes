#!/usr/bin/env bash
#MISE description="Restore obfuscated filenames to their original names"
#USAGE flag "--dir <dir>" default="notes" help="Notes directory relative to repo root (default: notes)"
#USAGE flag "--dry-run" default=#false help="Show what would be renamed without doing it"
#USAGE flag "--force" default=#false help="Overwrite existing readable files intentionally"
#USAGE arg "[files]" var=#true default="" help="Specific obfuscated IDs to deobfuscate. Omit for all."
set -euo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"
source "$MISE_CONFIG_ROOT/lib/obfuscate.sh"
source "$MISE_CONFIG_ROOT/lib/suppress.sh"
notes_dir="${usage_dir:-notes}"
abs_notes_dir="$TARGET_DIR/$notes_dir"
manifest="$abs_notes_dir/.manifest"

if [ ! -f "$manifest" ]; then
  echo "Error: no manifest found at $manifest" >&2
  exit 1
fi

# Parse variadic args safely (mise wraps multi-word args in single quotes).
# xargs respects shell quoting so spaces in filenames work correctly.
# Limitation: backslashes in filenames are treated as escape characters by xargs.
ARGS=()
if [ -n "${usage_files:-}" ]; then
  while IFS= read -r arg; do
    # Strip notes_dir prefix if provided (e.g. "notes/abc123" → "abc123")
    arg="${arg#"${notes_dir}/"}"
    # Skip empty variadic defaults after xargs unquotes "''".
    [ -z "$arg" ] && continue
    arg=$(basename "$arg")
    ARGS+=("$arg")
  done < <(printf '%s' "${usage_files}" | xargs printf '%s\n')
fi

if [ "${usage_dry_run:-}" = "true" ]; then
  # Dry-run: just show what would be renamed
  if [ ${#ARGS[@]} -gt 0 ]; then
    for id in ${ARGS[@]+"${ARGS[@]}"}; do
      relpath=$(manifest_name_for_id "$manifest" "$id")
      if [ -z "$relpath" ]; then
        echo "Warning: unknown ID '$id', skipping" >&2
        continue
      fi
      [ -f "$abs_notes_dir/$id" ] && echo "  $id → $relpath"
    done
  else
    while IFS=$'\t' read -r id relpath; do
      [ -z "$id" ] && continue
      [ -f "$abs_notes_dir/$id" ] && echo "  $id → $relpath"
    done < "$manifest"
  fi
  exit 0
fi

full_mode=true
if [ ${#ARGS[@]} -gt 0 ] && [ -n "${ARGS[0]}" ]; then
  full_mode=false
fi

# Reconcile stale readable files before restoring current manifest entries.
# This handles upstream deletion/rename cleanly: old generated readables are
# removed or quarantined before they can be mistaken for new notes.
stale_output=""
if $full_mode; then
  stale_output=$(reconcile_stale_readable_notes "$abs_notes_dir") || {
    echo "Error: failed to reconcile stale readable notes" >&2
    exit 1
  }
fi

# Perform the rename via Layer 1.
# Exit codes: 0=success, 2=nothing to do, 3=dirty readable preserved, 1=error.
# Use subshell to capture exit code without triggering errexit.
export NOTES_DEOBFUSCATE_FORCE="${usage_force:-false}"
output=$(rename_to_readable "$abs_notes_dir" ${ARGS[@]+"${ARGS[@]}"}) && rc=0 || rc=$?

# Print what was renamed, collect IDs. Do this even on partial failure so
# the state file stays consistent with disk; surface the rc afterwards.
restored=0
suppressed_ids=()
if [ -n "$output" ]; then
  while IFS=$'\t' read -r id relpath; do
    [ -z "$id" ] && continue
    echo "  $id → $relpath"
    suppressed_ids+=("$id")
    ((restored++)) || true
  done <<< "$output"
fi

removed_stale=0
quarantined_stale=0
if [ -n "$stale_output" ]; then
  while IFS=$'\t' read -r action relpath quarantine_path; do
    [ -n "$action" ] || continue
    case "$action" in
      removed)
        echo "  removed stale readable: $relpath" >&2
        ((removed_stale++)) || true
        ;;
      quarantined)
        echo "Warning: quarantined stale readable note: $relpath → $quarantine_path" >&2
        ((quarantined_stale++)) || true
        ;;
    esac
  done <<< "$stale_output"
fi

# Warn about unknown IDs in scoped mode (matches dry-run behavior)
if [ ${#ARGS[@]} -gt 0 ]; then
  for id in ${ARGS[@]+"${ARGS[@]}"}; do
    found=false
    for sid in ${suppressed_ids[@]+"${suppressed_ids[@]}"}; do
      [ "$sid" = "$id" ] && found=true && break
    done
    if [ "$found" = false ]; then
      echo "Warning: unknown or already-deobfuscated ID '$id', skipped" >&2
    fi
  done
fi

# Rebuild full suppression from current manifest after full deobfuscation. For
# scoped calls, update only the restored IDs to preserve partial-deobfuscation
# behavior.
if $full_mode; then
  rebuild_status_suppression "$abs_notes_dir" \
    || echo "Warning: failed to rebuild status suppression" >&2
elif [ ${#suppressed_ids[@]} -gt 0 ]; then
  set_status_suppression "$abs_notes_dir" ${suppressed_ids[@]+"${suppressed_ids[@]}"} \
    || echo "Warning: failed to update status suppression" >&2
fi

# Record state for what *did* succeed, even on partial failure. Tolerate
# helper errors with `|| warn` so the original rename rc isn't masked under
# `set -e`.
if [ ${#suppressed_ids[@]} -gt 0 ]; then
  _record_deobfuscation_base_hashes "$abs_notes_dir" ${suppressed_ids[@]+"${suppressed_ids[@]}"} \
    || echo "Warning: failed to record deobfuscation base hashes" >&2
fi

if [ $rc -ne 0 ] && [ $rc -ne 2 ]; then
  echo "Error: deobfuscation failed after restoring $restored file(s)" >&2
  exit $rc
fi

stale_total=$((removed_stale + quarantined_stale))
if [ $rc -eq 2 ] && [ "$restored" -eq 0 ] && [ "$stale_total" -eq 0 ]; then
  echo "Nothing to deobfuscate."
  exit 0
fi

echo ""
echo "Restored $restored file(s). Manifest preserved for stable IDs."
if [ "$stale_total" -gt 0 ]; then
  echo "Reconciled $stale_total stale readable file(s): $removed_stale removed, $quarantined_stale quarantined."
fi
echo ""
echo "Use 'notes changes' to see edits. Use 'notes commit -m \"...\" <file>' or 'notes commit --all -m \"...\"' to commit note changes."
