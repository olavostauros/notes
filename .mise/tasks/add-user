#!/usr/bin/env bash
#MISE description="Add a GPG collaborator who can decrypt this repo"
#USAGE flag "--gpg-key <fingerprint>" help="GPG key fingerprint" required=#true
set -eo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"
require_git
require_initialized
require_rudi

cd "$TARGET_DIR"
rudi add-user "$usage_gpg_key"
