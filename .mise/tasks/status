#!/usr/bin/env bash
#MISE description="Show encryption and obfuscation status"
#USAGE flag "--json" help="Output as JSON"
#USAGE flag "--dir <dir>" help="Notes directory name (default: notes)"
set -euo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"
require_git
require_rudi

JSON="${usage_json:-false}"
NOTES_DIR="${usage_dir:-notes}"

cd "$TARGET_DIR"

# --- Encryption (delegated to rudi) ---

rudi_json=$(rudi status --json)
enc_initialized=$(echo "$rudi_json" | jq -r '.initialized')
enc_unlocked=$(echo "$rudi_json" | jq -r '.unlocked')

if [ "$enc_initialized" = "true" ]; then
  if [ "$enc_unlocked" = "true" ]; then
    enc_status="unlocked"
  else
    enc_status="locked"
  fi
else
  enc_status="not_initialized"
  enc_unlocked=false
fi

# --- Obfuscation ---
# When locked, encrypted files (including the manifest) are binary gibberish.
# Skip obfuscation detection entirely — it's meaningless on a locked repo.

obf_status="none"
total_notes=0

if [ "$enc_status" != "locked" ] && [ -f "$NOTES_DIR/.manifest" ]; then
  total_notes=$(wc -l < "$NOTES_DIR/.manifest" | tr -d ' ')
  first_hash=$(head -1 "$NOTES_DIR/.manifest" | cut -f1)
  first_name=$(head -1 "$NOTES_DIR/.manifest" | cut -f2)

  if [ -n "$first_name" ] && [ -f "$NOTES_DIR/$first_name" ]; then
    obf_status="deobfuscated"
  elif [ -n "$first_hash" ] && [ -f "$NOTES_DIR/$first_hash" ]; then
    obf_status="obfuscated"
  fi
fi

# --- Output ---

if [ "$JSON" = "true" ]; then
  if [ "$enc_status" = "locked" ]; then
    jq -nc \
      --arg enc "$enc_status" \
      --argjson enc_unlocked "$enc_unlocked" \
      '{
        encryption: { status: $enc, unlocked: $enc_unlocked },
        obfuscation: { status: "unknown", notes: null }
      }'
  else
    jq -nc \
      --arg enc "$enc_status" \
      --argjson enc_unlocked "$enc_unlocked" \
      --arg obf "$obf_status" \
      --argjson total_notes "$total_notes" \
      '{
        encryption: { status: $enc, unlocked: $enc_unlocked },
        obfuscation: { status: $obf, notes: $total_notes }
      }'
  fi
else
  echo "Encryption: $enc_status"
  if [ "$enc_status" != "not_initialized" ]; then
    rudi status
  fi
  echo ""
  if [ "$enc_status" = "locked" ]; then
    echo "Obfuscation: unknown (repo is locked)"
    echo ""
    echo "Run 'notes unlock' to decrypt files and see obfuscation status."
  else
    echo "Obfuscation: $obf_status ($total_notes notes)"
  fi
fi
