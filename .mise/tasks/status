#!/usr/bin/env bash
#MISE description="Show encryption and obfuscation status"
#USAGE flag "--json" help="Output as JSON"
set -euo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"
require_git

JSON="${usage_json:-false}"

cd "$TARGET_DIR"

# --- Encryption ---

enc_status="not_initialized"
enc_unlocked=false
if is_initialized; then
  if command -v rudi &>/dev/null; then
    if rudi status -e &>/dev/null 2>&1; then
      enc_status="unlocked"
      enc_unlocked=true
    else
      enc_status="locked"
    fi
  else
    enc_status="rudi_missing"
  fi
fi

# --- Obfuscation ---

obf_status="none"
obf_count=0
total_notes=0
if [ -f "notes/.manifest" ]; then
  total_notes=$(wc -l < "notes/.manifest" | tr -d ' ')
  first_hash=$(head -1 "notes/.manifest" | cut -f1)
  first_name=$(head -1 "notes/.manifest" | cut -f2)

  if [ -n "$first_name" ] && [ -f "notes/$first_name" ]; then
    obf_status="deobfuscated"
  elif [ -n "$first_hash" ] && [ -f "notes/$first_hash" ]; then
    obf_status="obfuscated"
  fi
  obf_count=$total_notes
fi

# --- Output ---

if [ "$JSON" = "true" ]; then
  jq -nc \
    --arg enc "$enc_status" \
    --argjson enc_unlocked "$enc_unlocked" \
    --arg obf "$obf_status" \
    --argjson obf_count "$obf_count" \
    --argjson total_notes "$total_notes" \
    '{
      encryption: { status: $enc, unlocked: $enc_unlocked },
      obfuscation: { status: $obf, notes: $total_notes }
    }'
else
  echo "Encryption: $enc_status"
  if command -v rudi &>/dev/null && is_initialized; then
    rudi status
  fi
  echo ""
  echo "Obfuscation: $obf_status ($total_notes notes)"
fi
