#!/usr/bin/env bash
#MISE description="Generate index.md from note frontmatter"
#USAGE flag "--dir <dir>" help="Notes directory relative to repo root (default: notes)"
set -eo pipefail

TARGET_DIR="${CALLER_PWD:-.}"
notes_dir="$TARGET_DIR/${usage_dir:-notes}"

if ! command -v farts &>/dev/null; then
  echo "Error: farts not found. Install it: shiv install farts" >&2
  exit 1
fi

if [ ! -d "$notes_dir" ]; then
  echo "Error: notes directory not found: $notes_dir" >&2
  exit 1
fi

# Temp files as key-value stores (bash 3.2 compatible, no associative arrays)
tmp_titles=$(mktemp)
tmp_created=$(mktemp)
tmp_updated=$(mktemp)
tmp_tag_slugs=$(mktemp)
tmp_slugs=$(mktemp)
tmp_unconverted=$(mktemp)
tmp_all_tags=$(mktemp)
trap 'rm -f "$tmp_titles" "$tmp_created" "$tmp_updated" "$tmp_tag_slugs" "$tmp_slugs" "$tmp_unconverted" "$tmp_all_tags"' EXIT

# Helpers: get value by key from a tab-separated temp file
kv_get() { grep "^${2}	" "$1" 2>/dev/null | head -1 | cut -f2-; }
kv_has() { grep -q "^${2}	" "$1" 2>/dev/null; }

# Collect note metadata using farts
for f in "$notes_dir"/*.md; do
  [ ! -f "$f" ] && continue
  base=$(basename "$f")
  slug="${base%.md}"

  title=$(farts get title "$f" 2>/dev/null || true)
  if [ -z "$title" ]; then
    # Track files without frontmatter (skip generated files)
    [[ "$base" != "index.md" && "$base" != "graph.md" ]] && echo "$base" >> "$tmp_unconverted"
    continue
  fi

  echo "$slug" >> "$tmp_slugs"
  printf '%s\t%s\n' "$slug" "$title" >> "$tmp_titles"
  printf '%s\t%s\n' "$slug" "$(farts get created "$f" 2>/dev/null || true)" >> "$tmp_created"
  printf '%s\t%s\n' "$slug" "$(farts get updated "$f" 2>/dev/null || true)" >> "$tmp_updated"

  # Collect tags for this note
  while IFS= read -r tag; do
    [ -z "$tag" ] && continue
    echo "$tag:$slug" >> "$tmp_all_tags"
  done < <(farts get tags "$f" 2>/dev/null || true)
done

# Sort slugs alphabetically
sorted_slugs=()
while IFS= read -r s; do
  sorted_slugs+=("$s")
done < <(sort "$tmp_slugs" 2>/dev/null)

# Build tag index: tag -> sorted list of slugs
sorted_unique_tags=()
if [ -s "$tmp_all_tags" ]; then
  while IFS= read -r entry; do
    tag="${entry%%:*}"
    slug="${entry#*:}"
    if kv_has "$tmp_tag_slugs" "$tag"; then
      # Append slug to existing entry
      existing=$(kv_get "$tmp_tag_slugs" "$tag")
      # Remove old line and add updated one
      grep -v "^${tag}	" "$tmp_tag_slugs" > "$tmp_tag_slugs.tmp" || true
      mv "$tmp_tag_slugs.tmp" "$tmp_tag_slugs"
      printf '%s\t%s\n' "$tag" "$existing $slug" >> "$tmp_tag_slugs"
    else
      printf '%s\t%s\n' "$tag" "$slug" >> "$tmp_tag_slugs"
    fi
  done < "$tmp_all_tags"

  while IFS= read -r t; do
    sorted_unique_tags+=("$t")
  done < <(cut -f1 "$tmp_tag_slugs" | sort -u)
fi

# --- Generate index.md ---
{
  echo "# Shared Notes"
  echo ""
  echo "Auto-generated index. Do not edit manually — run \`notes index\` to rebuild."
  echo ""

  # Tag cloud
  echo "## Tags"
  echo ""
  if [ ${#sorted_unique_tags[@]} -eq 0 ]; then
    echo "*No tags yet.*"
  else
    cloud=""
    for tag in "${sorted_unique_tags[@]}"; do
      slugs_for_tag=$(kv_get "$tmp_tag_slugs" "$tag")
      count=$(echo "$slugs_for_tag" | tr ' ' '\n' | wc -l | tr -d ' ')
      cloud+="\`$tag\` ($count) "
    done
    echo "$cloud"
  fi
  echo ""

  # By-tag index
  echo "## Notes by Tag"
  echo ""
  for tag in "${sorted_unique_tags[@]}"; do
    echo "### $tag"
    echo ""
    slugs_for_tag=$(kv_get "$tmp_tag_slugs" "$tag")
    while IFS= read -r slug; do
      [ -z "$slug" ] && continue
      dates=""
      c=$(kv_get "$tmp_created" "$slug")
      u=$(kv_get "$tmp_updated" "$slug")
      [ -n "$c" ] && dates="created $c"
      if [ -n "$u" ]; then
        [ -n "$dates" ] && dates+=", "
        dates+="updated $u"
      fi
      [ -n "$dates" ] && dates=" ($dates)"
      title=$(kv_get "$tmp_titles" "$slug")
      echo "- [$title]($slug.md)$dates"
    done < <(echo "$slugs_for_tag" | tr ' ' '\n' | sort)
    echo ""
  done

  # All notes table
  echo "## All Notes"
  echo ""
  echo "| Note | Tags | Updated |"
  echo "|------|------|---------|"
  for slug in "${sorted_slugs[@]}"; do
    # Collect tags for this slug
    slug_tags=""
    for tag in "${sorted_unique_tags[@]}"; do
      slugs_for_tag=$(kv_get "$tmp_tag_slugs" "$tag")
      if echo " $slugs_for_tag " | grep -q " $slug "; then
        [ -n "$slug_tags" ] && slug_tags+=", "
        slug_tags+="$tag"
      fi
    done
    u=$(kv_get "$tmp_updated" "$slug")
    up="${u:-—}"
    title=$(kv_get "$tmp_titles" "$slug")
    echo "| [$title]($slug.md) | $slug_tags | $up |"
  done
  echo ""

  # Unconverted notes
  echo "## Notes Without Frontmatter"
  echo ""
  if [ ! -s "$tmp_unconverted" ]; then
    echo "*All notes have frontmatter.*"
  else
    while IFS= read -r fname; do
      echo "- [$fname]($fname)"
    done < <(sort "$tmp_unconverted")
  fi
  echo ""
} > "$notes_dir/index.md"

echo "  index.md generated (${#sorted_slugs[@]} indexed notes, ${#sorted_unique_tags[@]} tags)"
