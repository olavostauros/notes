#!/usr/bin/env python3
#MISE description="Generate graph.md — backlink map from wikilinks and relations"
#USAGE flag "--dir <dir>" help="Notes directory relative to repo root (default: notes)"

import os
import re
import sys
from collections import defaultdict
from pathlib import Path


def parse_frontmatter(text):
    lines = text.split("\n")
    if not lines or lines[0].strip() != "---":
        return {}

    fm = {}
    for line in lines[1:]:
        if line.strip() == "---":
            break
        if ":" in line:
            key, _, val = line.partition(":")
            fm[key.strip()] = val.strip()

    result = {}
    result["title"] = fm.get("title", "").strip("\"'")

    for field in ("tags", "related"):
        raw = fm.get(field, "")
        if raw.startswith("[") and raw.endswith("]"):
            items = [i.strip().strip("\"'") for i in raw[1:-1].split(",") if i.strip()]
            result[field] = items
        else:
            result[field] = []

    return result


def scan_wiki_links(text):
    parts = text.split("---", 2)
    body = parts[2] if len(parts) >= 3 else text
    return sorted(set(re.findall(r"\[\[([a-z0-9-]+)(?:\|[^\]]+)?\]\]", body)))


def main():
    target_dir = os.environ.get("NOTES_CALLER_PWD") or os.environ.get("CALLER_PWD", ".")
    notes_subdir = os.environ.get("usage_dir", "notes")
    notes_dir = Path(target_dir) / notes_subdir

    if not notes_dir.is_dir():
        print(f"Error: notes directory not found: {notes_dir}", file=sys.stderr)
        sys.exit(1)

    notes = {}
    backlinks = defaultdict(list)

    for f in sorted(notes_dir.glob("*.md")):
        slug = f.stem
        text = f.read_text()
        fm = parse_frontmatter(text)

        if not fm or not fm.get("title"):
            continue

        links = scan_wiki_links(text)
        notes[slug] = {**fm, "links": links}

        for link in links:
            backlinks[link].append(slug)

    sorted_slugs = sorted(notes.keys())

    lines = [
        "# Link Graph",
        "",
        "Auto-generated backlink map. Do not edit manually — run `notes graph` to rebuild.",
        "",
    ]

    # Outgoing links
    lines.append("## Outgoing Links")
    lines.append("")
    has_outgoing = False
    for slug in sorted_slugs:
        n = notes[slug]
        if n["links"]:
            link_str = ", ".join(f"[[{l}]]" for l in n["links"])
            lines.append(f"- **{n['title']}** ({slug}) -> {link_str}")
            has_outgoing = True
    if not has_outgoing:
        lines.append("*No outgoing links yet.*")
    lines.append("")

    # Backlinks
    lines.append("## Backlinks (Incoming)")
    lines.append("")
    sorted_bl = sorted(backlinks.keys())
    if not sorted_bl:
        lines.append("*No backlinks found yet.*")
    else:
        for target in sorted_bl:
            sources = backlinks[target]
            target_title = notes[target]["title"] if target in notes else target
            source_str = ", ".join(
                f"[[{s}]] ({notes[s]['title']})" if s in notes else f"[[{s}]]"
                for s in sorted(sources)
            )
            lines.append(f"- **{target_title}** ({target}) <- {source_str}")
    lines.append("")

    # Explicit relations
    lines.append("## Explicit Relations (frontmatter)")
    lines.append("")
    has_relations = False
    for slug in sorted_slugs:
        n = notes[slug]
        related = n.get("related", [])
        if related:
            rel_str = ", ".join(f"[[{r}]]" for r in related)
            lines.append(f"- **{n['title']}** ({slug}) <-> {rel_str}")
            has_relations = True
    if not has_relations:
        lines.append("*No explicit relations defined yet.*")
    lines.append("")

    # Orphaned notes
    lines.append("## Orphaned Notes (no links)")
    lines.append("")
    has_orphans = False
    for slug in sorted_slugs:
        n = notes[slug]
        has_links = bool(n["links"])
        has_bl = slug in backlinks
        has_rel = bool(n.get("related", []))
        if not has_links and not has_bl and not has_rel:
            lines.append(f"- [{n['title']}]({slug}.md)")
            has_orphans = True
    if not has_orphans:
        lines.append("*All notes are connected.*")
    lines.append("")

    (notes_dir / "graph.md").write_text("\n".join(lines))
    print(f"  graph.md generated ({len(sorted_bl)} notes with backlinks)")


if __name__ == "__main__":
    main()
