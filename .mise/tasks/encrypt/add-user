#!/usr/bin/env bash
#MISE description="Add a GPG collaborator who can decrypt this repo"
#USAGE flag "--gpg-key <fingerprint>" help="GPG key fingerprint" required=true
set -eo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
source "$REPO_DIR/lib/common.sh"
require_git
require_initialized

fingerprint="$usage_gpg_key"

if ! gpg --list-keys "$fingerprint" &>/dev/null; then
  echo "Error: key $fingerprint not found in GPG keyring." >&2
  echo "Import the public key first: gpg --import <pubkey.asc>" >&2
  exit 1
fi

uid=$(gpg --list-keys --with-colons "$fingerprint" | awk -F: '/^uid/{print $10; exit}')
echo "Adding collaborator: ${uid:-$fingerprint}"
git -C "$TARGET_DIR" crypt add-gpg-user --trusted "$fingerprint"
echo "Done. They can now run 'notes encrypt:unlock' to decrypt."
