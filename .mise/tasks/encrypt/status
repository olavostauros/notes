#!/usr/bin/env bash
#MISE description="Show encryption status"
set -eo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
source "$REPO_DIR/lib/common.sh"
require_git

echo "=== Encryption Status ==="
echo ""

# --- git-crypt binary ---
if command -v git-crypt &>/dev/null; then
  echo "  git-crypt:     $(git-crypt --version 2>&1) ($(which git-crypt))"
else
  echo "  git-crypt:     NOT INSTALLED"
  exit 0
fi

# --- Initialized? ---
if ! is_initialized; then
  echo "  initialized:   no — run: notes encrypt:setup"
  exit 0
fi
echo "  initialized:   yes"

# --- Locked/unlocked ---
if git -C "$TARGET_DIR" crypt status -e &>/dev/null; then
  echo "  state:         unlocked"
else
  echo "  state:         locked — run: notes encrypt:unlock"
fi

# --- Collaborators ---
echo ""
echo "  Collaborators:"
KEYS_DIR="$TARGET_DIR/.git-crypt/keys/default/0"
if [ -d "$KEYS_DIR" ]; then
  for keyfile in "$KEYS_DIR"/*.gpg; do
    [ -f "$keyfile" ] || { echo "    (none)"; break; }
    fingerprint=$(basename "$keyfile" .gpg)
    uid=$(gpg --list-keys --with-colons "$fingerprint" 2>/dev/null \
      | awk -F: '/^uid/{print $10; exit}')
    echo "    ${uid:-unknown} ($fingerprint)"
  done
else
  echo "    (none)"
fi

# --- Encrypted patterns ---
echo ""
echo "  Encrypted patterns (from .gitattributes):"
if [ -f "$TARGET_DIR/.gitattributes" ]; then
  grep "git-crypt" "$TARGET_DIR/.gitattributes" | grep -v "^#" | awk '{printf "    %s\n", $1}' || echo "    (none configured)"
else
  echo "    (no .gitattributes)"
fi

echo ""
