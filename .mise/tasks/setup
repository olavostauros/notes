#!/usr/bin/env bash
#MISE description="Initialize encryption in the current repo"
#USAGE flag "--gpg-key <fingerprint>" var=#true help="GPG key fingerprint(s) to add as collaborators"
#USAGE flag "--pattern <pattern>" var=#true help="Gitattributes patterns to encrypt (default: notes/**)"
#USAGE flag "--unlock" help="Unlock after setup (for joining an existing repo)"
set -eo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"
require_git
require_rudi

# Ensure rudi operates on the target repo (shiv shims set CALLER_PWD=$PWD)
cd "$TARGET_DIR"

# --- Initialize via rudi ---
if is_initialized || [ -d "$TARGET_DIR/.git/git-crypt" ]; then
  echo "git-crypt already initialized — updating auxiliary files..."
else
  echo "Initializing git-crypt..."
  rudi init --no-user
fi

# --- Add GPG keys via rudi ---
if [ -n "${usage_gpg_key:-}" ]; then
  echo ""
  echo "Adding GPG collaborators..."

  IFS=$'\n' read -r -d '' -a keys <<< "$usage_gpg_key" || true
  skipped=0
  for key in "${keys[@]}"; do
    [ -z "$key" ] && continue
    if gpg --list-keys "$key" &>/dev/null; then
      uid=$(gpg --list-keys --with-colons "$key" 2>/dev/null \
        | awk -F: '/^uid/{print $10; exit}')
      echo "  + ${uid:-$key}"
      rudi add-user "$key"
    else
      echo "  - $key — not in local keyring, skipping" >&2
      skipped=$((skipped + 1))
    fi
  done

  if [ "$skipped" -gt 0 ]; then
    echo ""
    echo "  $skipped key(s) skipped. Import them first: gpg --import <pubkey.asc>"
    echo "  Then run: notes add-user --gpg-key <fingerprint>"
  fi
fi

# --- Configure .gitattributes via rudi ---
GITATTRIBUTES="$TARGET_DIR/.gitattributes"
if ! grep -q "git-crypt" "$GITATTRIBUTES" 2>/dev/null; then
  echo ""
  echo "Configuring encrypted patterns..."

  if [ -n "${usage_pattern:-}" ]; then
    IFS=$'\n' read -r -d '' -a patterns <<< "$usage_pattern" || true
  else
    patterns=("notes/**")
  fi

  for p in "${patterns[@]}"; do
    [ -z "$p" ] && continue
    rudi assign "$p"
  done

  echo "  Updated .gitattributes"
else
  echo ""
  echo "  .gitattributes already has git-crypt patterns, skipping"
fi

# --- Bootstrap obfuscation manifest ---
NOTES_DIR="${usage_dir:-notes}"
if [ ! -f "$TARGET_DIR/$NOTES_DIR/.manifest" ]; then
  mkdir -p "$TARGET_DIR/$NOTES_DIR"
  touch "$TARGET_DIR/$NOTES_DIR/.manifest"
  echo "  Created $NOTES_DIR/.manifest (enables filename obfuscation)"
fi

# --- Install hooks ---
install_encryption_hook
install_obfuscation_hook "$NOTES_DIR"
install_deobfuscation_hook "$NOTES_DIR"
install_manifest_merge_driver "$NOTES_DIR"
echo "  Installed hooks"

# --- Unlock if requested ---
if [ "${usage_unlock:-false}" = "true" ]; then
  echo ""
  echo "Unlocking..."
  cd "$MISE_CONFIG_ROOT" && CALLER_PWD="$TARGET_DIR" mise run -q unlock
  echo ""
  echo "Done! Repo is set up and unlocked."
else
  # Detect if this is an existing repo with encrypted notes
  # (i.e., joining an existing repo vs creating a new one).
  has_encrypted_notes=false
  if [ -d "$TARGET_DIR/$NOTES_DIR" ]; then
    encrypted_file=$(find "$TARGET_DIR/$NOTES_DIR" -type f ! -name .manifest -print -quit 2>/dev/null)
    if [ -n "$encrypted_file" ] && head -c 10 "$encrypted_file" 2>/dev/null | grep -q "GITCRYPT"; then
      has_encrypted_notes=true
    fi
  fi

  echo ""
  echo "Done! Next steps:"
  if [ "$has_encrypted_notes" = "true" ]; then
    echo "  1. Unlock the repo:  notes unlock"
    echo "  2. Check status:     notes status"
    echo ""
    echo "  This repo already has encrypted notes."
    echo "  Run 'notes unlock' to decrypt them (requires your GPG key)."
    echo "  Or re-run setup with --unlock: notes setup --unlock"
  else
    echo "  1. Check status:     notes status"
    echo "  2. Commit the setup: git add .gitattributes .git-crypt && git commit"
    echo "  3. Place files in encrypted paths — they encrypt on push"
  fi
fi
