#!/usr/bin/env bash
#MISE description="Initialize encryption in the current repo"
#USAGE flag "--gpg-key <fingerprint>" var=#true help="GPG key fingerprint(s) to add as collaborators"
#USAGE flag "--pattern <pattern>" var=#true help="Gitattributes patterns to encrypt (default: notes/**)"
set -eo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"
require_git
require_rudi

# Ensure rudi operates on the target repo (shiv shims set CALLER_PWD=$PWD)
cd "$TARGET_DIR"

# --- Initialize via rudi ---
if is_initialized || [ -d "$TARGET_DIR/.git/git-crypt" ]; then
  echo "git-crypt already initialized — updating auxiliary files..."
else
  echo "Initializing git-crypt..."
  rudi init
fi

# --- Add GPG keys via rudi ---
if [ -n "${usage_gpg_key:-}" ]; then
  echo ""
  echo "Adding GPG collaborators..."

  IFS=$'\n' read -r -d '' -a keys <<< "$usage_gpg_key" || true
  skipped=0
  for key in "${keys[@]}"; do
    [ -z "$key" ] && continue
    if gpg --list-keys "$key" &>/dev/null; then
      uid=$(gpg --list-keys --with-colons "$key" 2>/dev/null \
        | awk -F: '/^uid/{print $10; exit}')
      echo "  + ${uid:-$key}"
      rudi add-user "$key"
    else
      echo "  - $key — not in local keyring, skipping" >&2
      skipped=$((skipped + 1))
    fi
  done

  if [ "$skipped" -gt 0 ]; then
    echo ""
    echo "  $skipped key(s) skipped. Import them first: gpg --import <pubkey.asc>"
    echo "  Then run: notes add-user --gpg-key <fingerprint>"
  fi
fi

# --- Configure .gitattributes via rudi ---
GITATTRIBUTES="$TARGET_DIR/.gitattributes"
if ! grep -q "git-crypt" "$GITATTRIBUTES" 2>/dev/null; then
  echo ""
  echo "Configuring encrypted patterns..."

  if [ -n "${usage_pattern:-}" ]; then
    IFS=$'\n' read -r -d '' -a patterns <<< "$usage_pattern" || true
  else
    patterns=("notes/**")
  fi

  for p in "${patterns[@]}"; do
    [ -z "$p" ] && continue
    rudi assign "$p"
  done

  echo "  Updated .gitattributes"
else
  echo ""
  echo "  .gitattributes already has git-crypt patterns, skipping"
fi

# --- Install pre-commit hook ---
HOOK="$TARGET_DIR/.git/hooks/pre-commit"
cat > "$HOOK" <<'HOOK_EOF'
#!/usr/bin/env bash
# Prevent accidentally committing plaintext files that should be encrypted.
set -eo pipefail

if ! command -v git-crypt &>/dev/null; then
  echo "WARNING: git-crypt not found — skipping encryption check" >&2
  exit 0
fi

bad_files=()
encrypted_files=$(git-crypt status -e 2>/dev/null | awk '{print $2}' || true)
[ -z "$encrypted_files" ] && exit 0

while IFS= read -r file; do
  if echo "$encrypted_files" | grep -qxF "$file"; then
    if git-crypt status "$file" 2>&1 | grep -q "not encrypted"; then
      bad_files+=("$file")
    fi
  fi
done < <(git diff --cached --name-only --diff-filter=ACM)

if [ "${#bad_files[@]}" -gt 0 ]; then
  echo "ERROR: Staged files should be encrypted but are plaintext:" >&2
  printf '  %s\n' "${bad_files[@]}" >&2
  echo "" >&2
  echo "Run 'notes unlock' if git-crypt is locked, then re-stage." >&2
  exit 1
fi
HOOK_EOF

# Append obfuscation check (unquoted heredoc so notes_dir is baked in)
notes_dir="${usage_dir:-notes}"
cat >> "$HOOK" <<HOOK_EOF

# --- Check filename obfuscation ---
# If a manifest exists, all note files must have obfuscated names.
NOTES_ROOT="$notes_dir"

if [ -f "\$NOTES_ROOT/.manifest" ]; then
  declare -A valid_ids
  while IFS=\$'\t' read -r id name; do
    [ -z "\$id" ] && continue
    valid_ids[\$id]=1
  done < "\$NOTES_ROOT/.manifest"

  unobfuscated=()
  while IFS= read -r file; do
    [[ "\$file" != "\$NOTES_ROOT/"* ]] && continue
    base=\$(basename "\$file")
    [[ "\$base" == ".manifest" ]] && continue
    if [ -z "\${valid_ids[\$base]+x}" ]; then
      unobfuscated+=("\$file")
    fi
  done < <(git diff --cached --name-only --diff-filter=ACM)

  if [ "\${#unobfuscated[@]}" -gt 0 ]; then
    echo "ERROR: Staged notes have non-obfuscated filenames:" >&2
    printf '  %s\n' "\${unobfuscated[@]}" >&2
    echo "" >&2
    echo "Run 'notes obfuscate' first, then re-stage." >&2
    exit 1
  fi
fi
HOOK_EOF
chmod +x "$HOOK"
echo "  Installed pre-commit hook"

echo ""
echo "Done! Next steps:"
echo "  1. Check status:     notes status"
echo "  2. Commit the setup: git add .gitattributes .git-crypt && git commit"
echo "  3. Place files in encrypted paths — they encrypt on push"
