#!/usr/bin/env bash
# Generic hook dispatcher — runs all executable scripts in <hook-name>.d/
# Used for pre-commit, post-commit, post-merge, and post-checkout hooks.
# Pre-commit: exits on first failure (blocks the commit).
# Post-commit/post-merge/post-checkout: continues on failure (git already moved).
set -eo pipefail

HOOK_NAME="$(basename "$0")"
HOOK_DIR="$(dirname "$0")/${HOOK_NAME}.d"

shopt -s nullglob
for hook in "$HOOK_DIR"/*; do
  if [ -x "$hook" ]; then
    if [[ "$HOOK_NAME" == pre-* ]]; then
      "$hook" "$@" || exit $?
    else
      "$hook" "$@" || echo "${HOOK_NAME} hook failed: $hook" >&2
    fi
  fi
done
